# Copy to .env for local Supabase mode.
# Leave APP_MODE=demo to run the app with in-memory seeded data.
APP_MODE=demo

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# These are server-side only. Set them as Supabase function secrets, never in Flutter.
FOOTBALL_DATA_TOKEN=
API_FOOTBALL_KEY=
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=
THESPORTSDB_KEY=123
